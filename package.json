{
	"name": "md2flomo",
	"version": "1.0.1",
	"description": "将 Obsidian 中的 Markdown 文档导入到 flomo",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"flomo",
		"plugin",
		"markdown",
		"import"
	],
	"author": "joeytoday",
	"license": "MIT",
	"dependencies": {
		"js-yaml": "^4.1.0"
	},
	"devDependencies": {
		"@types/js-yaml": "^4.0.5",
		"@types/node": "^18.19.0",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "^2.8.0",
		"typescript": "^5.7.0",
		"vitest": "^3.2.1"
	}
}
